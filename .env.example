# ClearScript — Environment Variables
# Copy this file to .env and fill in values as needed.

# ── Optional: Google Gemini Vision API (free tier) ────────────────────────────
# Get a free API key from: https://aistudio.google.com/apikey
# No billing account needed. Enables direct image-to-JSON extraction.
GEMINI_API_KEY=your_key_here

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
# Ollama runs locally. Just install it and pull models:
#   ollama pull mistral       (for text explanations)
#   ollama pull llava          (for vision/image understanding)
# No configuration needed — ClearScript auto-detects Ollama at localhost:11434.
